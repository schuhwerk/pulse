{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: serve",
      "type": "shell",
      "command": "php -S 127.0.0.1:8080",
      "isBackground": true,
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "panel": "dedicated", "reveal": "silent" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Development Server",
          "endsPattern": "Development Server"
        }
      }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "bun run test",
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "panel": "dedicated", "clear": true }
    },
    {
      "label": "test: headed",
      "type": "shell",
      "command": "bun run test:headed",
      "group": "test",
      "presentation": { "panel": "dedicated", "clear": true }
    },
    {
      "label": "test: ui",
      "type": "shell",
      "command": "bun run test:ui",
      "group": "test",
      "presentation": { "panel": "dedicated", "clear": true }
    },
    {
      "label": "open browser",
      "type": "shell",
      "command": "sleep 1 && xdg-open http://localhost:8080/index.html",
      "dependsOn": "dev: serve",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "silent", "panel": "never" },
      "problemMatcher": []
    },
    {
      "label": "install browsers",
      "type": "shell",
      "command": "bun run install-browsers",
      "presentation": { "panel": "dedicated", "clear": true }
    }
  ]
}
